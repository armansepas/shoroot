{
	"name": "TelegramConfig",
	"type": "object",
	"properties": {
		"bot_token": {
			"type": "string",
			"description": "The token for your Telegram bot."
		},
		"chat_id": {
			"type": "string",
			"description": "The ID of the channel or user to send reports to."
		},
		"is_enabled": {
			"type": "boolean",
			"default": false,
			"description": "Enable or disable sending reports."
		}
	},
	"required": ["bot_token", "chat_id"]
}
